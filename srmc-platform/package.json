{
  "name": "srmc-platform",
  "version": "1.0.0",
  "description": "SMS Broadcast Platform — Monorepo",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "start": "node apps/web/index.js",
    "dev": "node --watch apps/web/index.js",
    "start:web": "node apps/web/index.js",
    "start:desktop": "npm start -w @srmc/desktop",
    "client:dev": "npm run dev -w @srmc/client",
    "client:build": "npm run build -w @srmc/client",
    "build:desktop": "npm run build -w @srmc/desktop"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
