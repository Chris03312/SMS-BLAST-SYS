{
  "name": "srmc-platform",
  "version": "1.0.0",
  "description": "SRMC SMS Broadcast Platform — Desktop App",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "node server/index.js",
    "client": "cd client && npm run dev",
    "client:build": "cd client && npm run build",
    "electron": "electron .",
    "electron:dev": "node server/index.js & sleep 2 && electron .",
    "electron:build": "npm run client:build && electron-builder",
    "install:all": "npm install && cd client && npm install",
    "central": "cd central-server && node index.js",
    "central:install": "cd central-server && npm install"
  },
  "dependencies": {
    "@ngrok/ngrok": "^1.7.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.18.3",
    "jsonwebtoken": "^9.0.2",
    "node-fetch": "^3.3.2",
    "sql.js": "^1.14.1",
    "uuid": "^9.0.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^26.8.1",
    "markdown-pdf": "^11.0.0"
  },
  "build": {
    "appId": "com.srmc.platform",
    "productName": "SRMC Platform",
    "directories": {
      "output": "dist-electron",
      "buildResources": "build"
    },
    "asar": false,
    "files": [
      "electron/**/*",
      "!electron/make-icon.mjs",
      "server/**/*",
      "client/dist/**/*",
      ".env"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "electron/icon.png"
    },
    "portable": {
      "artifactName": "SRMC Platform Portable ${version}.exe"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "SRMC Platform"
    },
    "mac": {
      "target": "dmg",
      "icon": "electron/icon.png",
      "category": "public.app-category.business"
    },
    "linux": {
      "target": "AppImage",
      "icon": "electron/icon.png",
      "category": "Office"
    }
  }
}
