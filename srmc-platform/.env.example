# ── SMS Platform Environment Configuration ──────────────────────────────────
# This file documents ALL environment variables supported by the platform.
# Copy this to .env and fill in your values. Never commit a real .env.
#
# Priority order (highest wins):
#   1. Database settings table (configured via Admin → Settings page)
#   2. Environment variables (this file, set at OS/container level)
#   3. Hardcoded defaults in the code
#
# Database values always override env vars at runtime. Set a value here
# to use as fallback when the DB row is missing or empty.

# ── Server ───────────────────────────────────────────────────────────────────
SERVER_PORT=3003                  # HTTP port the server binds to
SERVER_HOST=http://192.168.3.239  # Default server URL (Electron desktop only)

# ── Admin account (seed/override on every boot) ──────────────────────────────
# If ADMIN_PASSWORD is set, the admin account is created or its password
# is reset to EXACTLY this value on every launch.
ADMIN_USERNAME=admin
# ADMIN_PASSWORD=your-strong-password-here

# ── Data directory ───────────────────────────────────────────────────────────
# Where SQLite database, backups, and secrets.json are stored.
# Default: <project>/data
# SRMC_DATA_DIR=/path/to/data

# ── Security secrets ─────────────────────────────────────────────────────────
# Auto-generated if left empty. Set these to override auto-generation.
# JWT_SECRET=change-me
# WEBHOOK_SECRET=whsec_your-webhook-secret-here

# ── Rate limiting ────────────────────────────────────────────────────────────
# All rate limits use a common window duration (default: 60 000 ms = 1 minute).
# Set any limit to 0 to disable rate limiting for that endpoint.
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_LOGIN=10          # Login attempts per window (per IP)
RATE_LIMIT_BROADCAST=30      # Broadcast creations per window (per user)
RATE_LIMIT_WEBHOOK=300       # Inbound webhook calls per window (per IP)
RATE_LIMIT_GATEWAY_OUTBOUND=60  # Gateway polling requests per window
RATE_LIMIT_NGROK=5           # Ngrok tunnel start/stop per window (per user)

# ── Ngrok tunnel configuration (fallback for DB values) ──────────────────────
# These are read from the database (Admin → Settings → Webhooks & API) first.
# Set them here ONLY as fallback when the DB is unavailable or the value is empty.
# NGROK_URL=https://your-name.ngrok-free.app
# NGROK_AUTHTOKEN=2abc123...your-ngrok-authtoken
# NGROK_TOKEN=2abc123...your-ngrok-token        # Alias for NGROK_AUTHTOKEN
# NGROK_DOMAIN=your-name.ngrok-free.dev

# ── Database-backed settings (overridable via env as fallback) ────────────────
# These settings are normally configured through Admin → Settings page.
# The values below are ONLY used when the DB setting is missing or empty.
# This is useful for Docker deployments where you inject config via env.
#
# Organisation
ORG_NAME=SMS Platform
SENDER_ID=SMSGATEWAY

# Sending behaviour
DELAY=6000                   # Default delay between SMS (ms)
TURBO_DELAY=100              # Turbo mode batch delay (ms)
TURBO_BATCH_SIZE=5           # Messages per turbo batch
DAILY_CAP=10000              # Soft daily message limit per agent
MAX_CONCURRENT_BROADCASTS=0  # Max simultaneous broadcasts (0=unlimited)
MAX_BROADCASTS_PER_AGENT=5   # Max active broadcasts per agent (0=unlimited)
MAX_RECIPIENTS_PER_BROADCAST=0  # Max recipients per broadcast (0=unlimited)
MAX_BROADCAST_DURATION_MINUTES=0 # Auto-cancel after N minutes (0=unlimited)
MAX_BROADCASTS_PER_DAY_PER_AGENT=0 # Daily broadcast creation limit (0=unlimited)

# Sending window (HH:MM format, 24-hour)
WINDOW_START=00:00
WINDOW_END=23:59

# Timezone
TIMEZONE=Asia/Manila

# Global pause
BROADCASTS_GLOBALLY_PAUSED=false

# Public / ngrok URL
PUBLIC_URL=

# Database backup
BACKUP_ENABLED=true
BACKUP_INTERVAL_MINUTES=1200
BACKUP_MAX_COPIES=6

# ── Electron auto-update (desktop app only) ──────────────────────────────────
# UPDATE_FEED_URL=https://releases.example.com/updates.json

# ── E-mail (optional - for password reset / notifications) ────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
