# ── SRMC Platform — Environment Configuration ───────────────────────────
# Copy this file to .env and fill in your values. Never commit a real .env.
#
# All settings below are FALLBACKS — they only take effect when the
# database has no value saved for that key (i.e. empty in Settings page).
# Once you save a value in the admin Settings page, the DB value wins.

# ── Server ──────────────────────────────────────────────────────────────
# Port and host the Express server binds to.
SERVER_HOST=http://192.168.3.239
SERVER_PORT=3003

# ── Initial admin account (first run only) ──────────────────────────────
# On a fresh database the app seeds ONE admin. Leave ADMIN_PASSWORD blank to
# auto-generate a strong password written to <dataDir>/INITIAL_ADMIN.txt, or
# set one explicitly here.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=SRMC@dmin2026

# ── JWT secret ──────────────────────────────────────────────────────────
# Used to sign auth tokens. The app generates a random one on first run
# and persists it to <userData>/secrets.json. Set explicitly only if you
# need a fixed secret shared across machines.
JWT_SECRET=srmc_secret_change_me

# ── Rate limiting ───────────────────────────────────────────────────────
# Protect the server from abuse. Rates are per IP per 1-minute window.
# Set to 0 to disable rate limiting for an endpoint.
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_LOGIN=10
RATE_LIMIT_BROADCAST=30
RATE_LIMIT_WEBHOOK=300
RATE_LIMIT_GATEWAY_OUTBOUND=60
RATE_LIMIT_NGROK=5

# ═════════════════════════════════════════════════════════════════════════
#  SETTINGS FALLBACKS — DB value > env var > hardcoded default
#  Set any of these in .env and they'll be used when the DB is empty.
# ═════════════════════════════════════════════════════════════════════════

# ── Networking ──────────────────────────────────────────────────────────
# Public URL visible to Android gateways (auto-set when ngrok tunnel starts).
PUBLIC_URL=
# ngrok tunnel URL for inbound webhook (auto-set on tunnel start).
NGROK_URL=
# ngrok auth token from ngrok.com — each device needs its own.
NGROK_AUTHTOKEN=
# Reserved ngrok domain (e.g. your-name.ngrok-free.dev).
NGROK_DOMAIN=
# Shared secret sent as Authorization header on outbound gateway requests.
WEBHOOK_SECRET=

# ── Branding ────────────────────────────────────────────────────────────
# Organisation name shown in agent consoles and exports.
ORG_NAME=SMS Platform
# Default alphanumeric sender ID (max 6 chars).
SENDER_ID=SMSGATEWAY

# ── Timing ──────────────────────────────────────────────────────────────
# Default delay between individual sends in normal mode (milliseconds).
DELAY=1000
# Delay between batches in Turbo mode (milliseconds).
TURBO_DELAY=50
# Messages per concurrent batch in Turbo mode.
TURBO_BATCH_SIZE=10
# Broadcasting window start (HH:MM).
WINDOW_START=00:00
# Broadcasting window end (HH:MM).
WINDOW_END=23:59
# Server timezone for all date/time displays.
TIMEZONE=Asia/Manila

# ── Volume limits ───────────────────────────────────────────────────────
# System-wide daily cap on total messages sent.
DAILY_CAP=100000
# How many broadcasts can run simultaneously (0 = unlimited).
MAX_CONCURRENT_BROADCASTS=3
# Active/queued broadcasts per agent (0 = unlimited).
MAX_BROADCASTS_PER_AGENT=20
# Maximum recipients per single broadcast (0 = unlimited).
MAX_RECIPIENTS_PER_BROADCAST=50000
# Max broadcasts an agent can create per day (0 = unlimited).
MAX_BROADCASTS_PER_DAY_PER_AGENT=50
# Auto-cancel broadcasts running longer than this (minutes, 0 = unlimited).
MAX_BROADCAST_DURATION_MINUTES=0
# Max contacts an agent can select per column in the Recipients page.
MAX_SELECTED_CONTACTS=200

# ── Global pause ────────────────────────────────────────────────────────
# Pause ALL broadcasts globally. Set to "true" to pause.
BROADCASTS_GLOBALLY_PAUSED=false
