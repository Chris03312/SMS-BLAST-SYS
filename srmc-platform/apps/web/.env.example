# ── SRMC Platform — Environment Configuration ───────────────────────────
# Copy this file to .env and fill in your values. Never commit a real .env.

# Server port (the embedded server + UI listen here).
PORT=3001
CENTRAL_SERVER_PORT=4000

# ── Initial admin account (first run only) ──────────────────────────────
# On a fresh database the app seeds ONE admin. Leave ADMIN_PASSWORD blank to
# auto-generate a strong password written to <dataDir>/INITIAL_ADMIN.txt, or
# set one explicitly here. No demo/agent accounts are created.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=SRMC@dmin2026

# ── Secrets ─────────────────────────────────────────────────────────────
# Leave these as the placeholders (or blank) and the app will generate a
# strong random secret on first run and persist it to <userData>/secrets.json.
# Set explicit values only if you need a fixed, shared secret across machines.
JWT_SECRET=srmc_secret_change_me
WEBHOOK_SECRET=srmc_webhook_secret_change_me

# ── Inbound tunnel (per-device) ─────────────────────────────────────────
# Each install opens its OWN ngrok tunnel so its Android gateways can deliver
# inbound SMS to THAT device. Prefer leaving these blank and setting the token
# (and optional reserved domain) per-device in the Settings page — free ngrok
# allows one tunnel per account, so use one token PER device.
NGROK_AUTHTOKEN=3AHnnGd9JErhBVo5IKr9tqByG6H_3SBnmt6bxN5DTkS11rqb8
NGROK_DOMAIN=unmouldy-roxann-commotive.ngrok-free.dev

# Option B — pin a fixed public URL instead of auto-tunneling (single machine).
NGROK_URL=

# ── Central reporting (optional) ────────────────────────────────────────
# The ADMIN server's public URL. Every install reports its stats here on boot
# and appears under "Remote Installations" on the admin dashboard. Leave blank
# to disable stats reporting.
CENTRAL_SERVER_URL=
CENTRAL_API_KEY=srmc_api_key_change_me
