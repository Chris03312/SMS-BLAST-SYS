{
  "name": "@srmc/desktop",
  "version": "1.0.0",
  "description": "SMS Platform — Electron Desktop App",
  "author": "SRMC Dev",
  "private": true,
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "build": "npm run build:client && electron-builder",
    "build:client": "npm run build -w @srmc/client",
    "build:win": "npm run build:client && electron-builder --win",
    "build:mac": "npm run build:client && electron-builder --mac",
    "build:linux": "npm run build:client && electron-builder --linux"
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "electron": "42.5.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.sms.platform",
    "productName": "SMS Platform",
    "directories": {
      "output": "dist-electron",
      "buildResources": "build"
    },
    "asar": false,
    "files": [
      "electron/**/*",
      "!electron/make-icon.mjs"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "electron/icon.ico"
    },
    "portable": {
      "artifactName": "SMS Platform Portable ${version}.exe"
    },
    "publish": {
      "provider": "generic",
      "url": "",
      "channel": "latest"
    },
    "generateUpdatesFilesForAllChannels": true,
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "SMS Platform"
    },
    "mac": {
      "target": "dmg",
      "icon": "electron/icon.ico",
      "category": "public.app-category.business"
    },
    "linux": {
      "target": "AppImage",
      "icon": "electron/icon.ico",
      "category": "Office"
    }
  }
}
