<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#EEF2F7">

    <!-- Top Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#1A73C8"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_name"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"/>

            <TextView
                android:id="@+id/tvDeviceModel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="11sp"
                android:textColor="#BBDEFB"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tvGatewayStatus"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:gravity="center"
            android:text="STOPPED"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textColor="#FFCDD2"
            android:background="#1565A8"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"/>
    </LinearLayout>

    <!-- Scrollable Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- ═══ GATEWAY CONTROL (always on top) ═══ -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="GATEWAY CONTROL"
                android:textSize="10sp"
                android:textColor="#94A3B8"
                android:letterSpacing="0.08"
                android:layout_marginBottom="6dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:padding="14dp"
                android:layout_marginBottom="10dp">

                <!-- Status + Toggle -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="STATUS"
                            android:textSize="10sp"
                            android:textColor="#94A3B8"
                            android:letterSpacing="0.06"
                            android:layout_marginBottom="4dp"/>

                        <TextView
                            android:id="@+id/tvStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Stopped"
                            android:textColor="#64748B"
                            android:textSize="14sp"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <Button
                        android:id="@+id/btnToggle"
                        android:layout_width="wrap_content"
                        android:layout_height="44dp"
                        android:text="START"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#1A73C8"
                        android:paddingStart="24dp"
                        android:paddingEnd="24dp"/>
                </LinearLayout>

                <!-- SIM Info -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="42dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="#F8FAFC"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:layout_marginBottom="4dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="SIM 1"
                        android:textColor="#1E293B"
                        android:textSize="13sp"/>

                    <TextView
                        android:id="@+id/tvSim1Carrier"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="not detected"
                        android:textColor="#1A73C8"
                        android:textSize="12sp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="42dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="#F8FAFC"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="SIM 2"
                        android:textColor="#1E293B"
                        android:textSize="13sp"/>

                    <TextView
                        android:id="@+id/tvSim2Carrier"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="not detected"
                        android:textColor="#1A73C8"
                        android:textSize="12sp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- ═══ INBOUND WEBHOOK ═══ -->
            <LinearLayout
                android:id="@+id/layoutServer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="INBOUND WEBHOOK"
                    android:textSize="10sp"
                    android:textColor="#94A3B8"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="6dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="#FFFFFF"
                    android:padding="14dp">

                    <!-- Server URL -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Server URL"
                        android:textSize="11sp"
                        android:textColor="#64748B"
                        android:layout_marginBottom="4dp"/>

                    <EditText
                        android:id="@+id/etServerUrl"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:hint="http://192.168.1.100:3000"
                        android:textColor="#1E293B"
                        android:textSize="13sp"
                        android:background="#FFFFFF"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:singleLine="true"
                        android:inputType="textUri"
                        android:imeOptions="actionDone"
                        android:layout_marginBottom="8dp"/>

                    <!-- Register button + status -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <Button
                            android:id="@+id/btnRegisterWebhook"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:text="Register Webhook"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF"
                            android:backgroundTint="#1A73C8"
                            android:paddingStart="20dp"
                            android:paddingEnd="20dp"/>

                        <TextView
                            android:id="@+id/tvWebhookStatus"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text=""
                            android:textSize="11sp"
                            android:textColor="#64748B"
                            android:gravity="end"
                            android:paddingStart="8dp"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- ═══ GATEWAY ENDPOINTS (visible only when running) ═══ -->
            <LinearLayout
                android:id="@+id/layoutEndpoints"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="GATEWAY ENDPOINTS"
                    android:textSize="10sp"
                    android:textColor="#94A3B8"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="6dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="#FFFFFF"
                    android:padding="14dp"
                    android:layout_marginBottom="10dp">

                    <!-- HTTP URL -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="HTTP URL"
                        android:textSize="10sp"
                        android:textColor="#94A3B8"
                        android:letterSpacing="0.06"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:id="@+id/tvEndpointUrl"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:text=""
                        android:textColor="#1A73C8"
                        android:textSize="13sp"
                        android:fontFamily="monospace"
                        android:gravity="center_vertical"
                        android:background="#F8FAFC"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:layout_marginBottom="10dp"/>

                    <!-- Health endpoint -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="HEALTH CHECK"
                        android:textSize="10sp"
                        android:textColor="#94A3B8"
                        android:letterSpacing="0.06"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:id="@+id/tvEndpointHealth"
                        android:layout_width="match_parent"
                        android:layout_height="36dp"
                        android:text=""
                        android:textColor="#0D9488"
                        android:textSize="12sp"
                        android:fontFamily="monospace"
                        android:gravity="center_vertical"
                        android:background="#F0FDFA"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:layout_marginBottom="10dp"/>

                    <!-- Send endpoint -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SEND SMS"
                        android:textSize="10sp"
                        android:textColor="#94A3B8"
                        android:letterSpacing="0.06"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:id="@+id/tvEndpointSend"
                        android:layout_width="match_parent"
                        android:layout_height="36dp"
                        android:text=""
                        android:textColor="#1D4ED8"
                        android:textSize="12sp"
                        android:fontFamily="monospace"
                        android:gravity="center_vertical"
                        android:background="#EFF6FF"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- ═══ GATEWAY INFO ═══ -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="GATEWAY INFO"
                android:textSize="10sp"
                android:textColor="#94A3B8"
                android:letterSpacing="0.08"
                android:layout_marginBottom="6dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:padding="14dp"
                android:layout_marginBottom="10dp">

                <!-- Device IP (read-only) -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DEVICE IP"
                    android:textSize="10sp"
                    android:textColor="#94A3B8"
                    android:letterSpacing="0.06"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:id="@+id/tvDeviceIp"
                    android:layout_width="match_parent"
                    android:layout_height="42dp"
                    android:text="Unknown"
                    android:textColor="#1A73C8"
                    android:textSize="14sp"
                    android:gravity="center_vertical"
                    android:background="#F8FAFC"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:layout_marginBottom="10dp"/>

                <!-- Gateway Port -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Gateway Port"
                    android:textSize="11sp"
                    android:textColor="#64748B"
                    android:layout_marginBottom="4dp"/>

                <EditText
                    android:id="@+id/etGatewayPort"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:hint="8088"
                    android:textColor="#1E293B"
                    android:textSize="14sp"
                    android:background="#FFFFFF"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:singleLine="true"
                    android:inputType="number"
                    android:imeOptions="actionDone"/>

                <!-- Separator -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#E2E8F0"
                    android:layout_marginTop="14dp"
                    android:layout_marginBottom="14dp"/>

                <!-- API Key -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="API KEY (long-press to regenerate)"
                    android:textSize="10sp"
                    android:textColor="#94A3B8"
                    android:letterSpacing="0.06"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:id="@+id/tvApiKey"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="#1A73C8"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:background="#F8FAFC"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp"
                    android:singleLine="false"
                    android:maxLines="4"
                    android:textIsSelectable="true"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
