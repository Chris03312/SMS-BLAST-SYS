<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EEF2F7"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:gravity="center"
            android:orientation="vertical"
            android:background="#1A73C8"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SMS Gateway"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SMS GATEWAY"
                android:textSize="11sp"
                android:textColor="#BBDEFB"
                android:textAllCaps="true"
                android:letterSpacing="0.15"/>

            <Button
                android:id="@+id/btnSettings"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Server Settings"
                android:textSize="11sp"
                android:layout_marginTop="16dp"
                android:backgroundTint="#1565A8"/>
        </LinearLayout>

        <!-- Form -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#F8FAFC"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Welcome back"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#1E293B"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sign in to continue to your account"
                android:textSize="13sp"
                android:textColor="#64748B"
                android:layout_marginBottom="20dp"/>

            <!-- Error card -->
            <LinearLayout
                android:id="@+id/cardError"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="#FEF2F2"
                android:padding="14dp"
                android:visibility="gone"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/tvError"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#B91C1C"
                    android:textSize="13sp"/>
            </LinearLayout>

            <!-- User ID -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="USER ID"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#64748B"
                android:letterSpacing="0.12"
                android:layout_marginBottom="6dp"/>

            <EditText
                android:id="@+id/etUserId"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Enter your user ID"
                android:textColor="#1E293B"
                android:textSize="14sp"
                android:background="#FFFFFF"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:singleLine="true"
                android:imeOptions="actionNext"
                android:inputType="text"
                android:layout_marginBottom="16dp"/>

            <!-- Password -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PASSWORD"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#64748B"
                android:letterSpacing="0.12"
                android:layout_marginBottom="6dp"/>

            <EditText
                android:id="@+id/etPassword"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Enter your password"
                android:textColor="#1E293B"
                android:textSize="14sp"
                android:background="#FFFFFF"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:singleLine="true"
                android:imeOptions="actionDone"
                android:inputType="textPassword"
                android:layout_marginBottom="28dp"/>

            <!-- Sign In -->
            <Button
                android:id="@+id/btnLogin"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Sign In"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:backgroundTint="#1A73C8"/>

            <!-- Progress -->
            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:visibility="gone"
                style="?android:attr/progressBarStyleHorizontal"/>

        </LinearLayout>

        <!-- Footer -->
        <TextView
            android:id="@+id/tvServerInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textColor="#94A3B8"
            android:textSize="11sp"
            android:background="#F8FAFC"
            android:paddingBottom="8dp"/>

    </LinearLayout>
</ScrollView>
