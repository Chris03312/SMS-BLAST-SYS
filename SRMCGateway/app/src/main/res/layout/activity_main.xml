<?xml version="1.0" encoding="utf-8"?>
<!--suppress SpellCheckingInspection -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_page">

    <!-- ══════════════════════════════════════════════════════════════
         TOP APP BAR
         ══════════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:background="@color/primary"
        android:gravity="center_vertical"
        android:baselineAligned="false"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvWelcomeUser"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_welcome"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:baselineAligned="false"
                android:layout_marginTop="2dp">

                <TextView
                    android:id="@+id/tvUserRole"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_user_role"
                    android:textSize="11sp"
                    android:textColor="#BBDEFB"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_separator"
                    android:textColor="#90CAF9"
                    android:textSize="11sp"/>

                <TextView
                    android:id="@+id/tvUserStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_active"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#A5D6A7"/>

            </LinearLayout>
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogout"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="@string/btn_logout"
            android:textColor="#FFCDD2"
            android:textSize="11sp"
            android:textStyle="bold"
            app:backgroundTint="@color/primary_dark"
            app:cornerRadius="10dp"
            app:strokeColor="#EF9A9A"
            app:strokeWidth="1dp"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"/>

    </LinearLayout>

    <!-- ══════════════════════════════════════════════════════════════
         BOTTOM NAVIGATION BAR
         ══════════════════════════════════════════════════════════════ -->
    <View
        android:id="@+id/navDivider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="@color/border_light"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:baselineAligned="false"
        android:background="@color/bg_card"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/btnTabDashboard"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/nav_icon_dashboard"
                android:textSize="20sp"
                android:textColor="@color/primary"
                android:layout_marginBottom="2dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/nav_dashboard"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/primary"/>

            <View
                android:layout_width="20dp"
                android:layout_height="3dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/nav_indicator"/>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnTabSettings"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/nav_icon_settings"
                android:textSize="20sp"
                android:textColor="@color/text_tertiary"
                android:layout_marginBottom="2dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/nav_settings"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/text_tertiary"/>

            <View
                android:layout_width="20dp"
                android:layout_height="3dp"
                android:layout_marginTop="4dp"
                android:background="@android:color/transparent"/>

        </LinearLayout>

    </LinearLayout>

    <!-- ══════════════════════════════════════════════════════════════
         SCROLLABLE BODY — constrained between top bar and bottom nav
         ══════════════════════════════════════════════════════════════ -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="false"
        android:overScrollMode="never"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintBottom_toTopOf="@id/navDivider"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="16dp">

            <!-- ══════════════════════════════════════════════════════
                 DASHBOARD TAB
                 ══════════════════════════════════════════════════════ -->
            <LinearLayout
                android:id="@+id/layoutDashboard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="visible">

                <!-- Error banner — FIX: app:drawableStartCompat + app:drawableTint -->
                <TextView
                    android:id="@+id/tvServerBanner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="@color/error_text"
                    android:textSize="12sp"
                    android:background="@drawable/banner_error_bg"
                    android:padding="12dp"
                    android:layout_marginBottom="12dp"
                    app:drawableStartCompat="@drawable/ic_error"
                    app:drawableTint="@color/error_text"
                    android:drawablePadding="10dp"
                    android:gravity="center_vertical"
                    android:visibility="gone"/>

                <!-- Gateway status card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/bg_card"
                    app:strokeColor="@color/border_light"
                    app:strokeWidth="1dp"
                    android:layout_marginBottom="12dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:baselineAligned="false"
                        android:padding="16dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/label_gateway_status"
                                android:textSize="11sp"
                                android:textColor="@color/text_tertiary"
                                android:letterSpacing="0.08"
                                android:layout_marginBottom="6dp"/>

                            <TextView
                                android:id="@+id/tvStatus"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/label_status_stopped"
                                android:textColor="@color/text_secondary"
                                android:textSize="15sp"
                                android:textStyle="bold"/>

                        </LinearLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnToggle"
                            android:layout_width="wrap_content"
                            android:layout_height="42dp"
                            android:text="@string/btn_start"
                            android:textColor="#FFFFFF"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.04"
                            app:backgroundTint="@color/primary"
                            android:paddingStart="24dp"
                            android:paddingEnd="24dp"
                            app:cornerRadius="10dp"/>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Stats row: SENT / FAILED / QUEUE -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="80dp"
                    android:orientation="horizontal"
                    android:baselineAligned="false"
                    android:layout_marginBottom="10dp">

                    <androidx.cardview.widget.CardView
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_marginEnd="5dp"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="@color/bg_card"
                        app:strokeColor="@color/border_light"
                        app:strokeWidth="1dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:padding="12dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/label_sent"
                                android:textSize="11sp"
                                android:textColor="@color/text_tertiary"
                                android:letterSpacing="0.06"/>
                            <TextView
                                android:id="@+id/tvSentCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/label_default_value"
                                android:textColor="@color/primary"
                                android:textSize="26sp"
                                android:textStyle="bold"
                                android:layout_marginTop="4dp"/>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <androidx.cardview.widget.CardView
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_marginStart="5dp"
                        android:layout_marginEnd="5dp"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="@color/bg_card"
                        app:strokeColor="@color/border_light"
                        app:strokeWidth="1dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:padding="12dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/label_failed"
                                android:textSize="11sp"
                                android:textColor="@color/text_tertiary"
                                android:letterSpacing="0.06"/>
                            <TextView
                                android:id="@+id/tvFailCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/label_default_value"
                                android:textColor="@color/error"
                                android:textSize="26sp"
                                android:textStyle="bold"
                                android:layout_marginTop="4dp"/>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <androidx.cardview.widget.CardView
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_marginStart="5dp"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="@color/bg_card"
                        app:strokeColor="@color/border_light"
                        app:strokeWidth="1dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:padding="12dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/label_queue"
                                android:textSize="11sp"
                                android:textColor="@color/text_tertiary"
                                android:letterSpacing="0.06"/>
                            <TextView
                                android:id="@+id/tvQueueCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/label_default_value"
                                android:textColor="#1D9E75"
                                android:textSize="26sp"
                                android:textStyle="bold"
                                android:layout_marginTop="4dp"/>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                </LinearLayout>

                <!-- MY SENT TODAY — full width, 80dp -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="80dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/primary_light"
                    app:strokeWidth="0dp"
                    android:layout_marginBottom="10dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:baselineAligned="false"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/label_my_sent_today"
                            android:textSize="12sp"
                            android:textColor="@color/primary_dark"
                            android:letterSpacing="0.06"/>
                        <TextView
                            android:id="@+id/tvMySentCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/label_default_value"
                            android:textColor="@color/primary"
                            android:textSize="32sp"
                            android:textStyle="bold"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- BLAST STATUS -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/bg_card"
                    app:strokeColor="@color/border_light"
                    app:strokeWidth="1dp"
                    android:layout_marginBottom="16dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:baselineAligned="false"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:paddingTop="10dp"
                        android:paddingBottom="10dp">
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/label_blast_status"
                                android:textSize="11sp"
                                android:textColor="@color/text_tertiary"
                                android:letterSpacing="0.06"
                                android:layout_marginBottom="4dp"/>
                            <TextView
                                android:id="@+id/tvSendingStatus"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/label_start_gateway_to_sync"
                                android:textColor="@color/text_hint"
                                android:textSize="11sp"/>
                        </LinearLayout>
                        <TextView
                            android:id="@+id/tvLastUpdated"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textColor="@color/text_tertiary"
                            android:textSize="11sp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Message Logs header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:baselineAligned="false"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/label_message_logs"
                        android:textSize="11sp"
                        android:textColor="@color/text_tertiary"
                        android:letterSpacing="0.06"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnClearLog"
                        android:layout_width="wrap_content"
                        android:layout_height="34dp"
                        android:text="@string/btn_clear"
                        android:textColor="@color/error"
                        android:textSize="11sp"
                        app:backgroundTint="@color/error_bg"
                        app:cornerRadius="10dp"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"/>

                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    tools:listitem="@layout/item_log"/>

            </LinearLayout>

            <!-- ══════════════════════════════════════════════════════
                 SETTINGS TAB
                 ══════════════════════════════════════════════════════ -->
            <LinearLayout
                android:id="@+id/layoutSettings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <!-- SMS SERVER section -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_srmc_sms_server"
                    android:textSize="11sp"
                    android:textColor="@color/text_tertiary"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="8dp"/>

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/bg_card"
                    app:strokeColor="@color/border_light"
                    app:strokeWidth="1dp"
                    android:layout_marginBottom="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp"
                            android:hint="@string/hint_server_ip"
                            app:startIconDrawable="@drawable/ic_server"
                            app:startIconTint="@color/icon_muted"
                            app:boxStrokeColor="@color/primary"
                            app:boxStrokeWidth="1dp"
                            app:boxStrokeWidthFocused="1.5dp"
                            app:hintTextColor="@color/primary"
                            app:boxCornerRadiusTopStart="10dp"
                            app:boxCornerRadiusTopEnd="10dp"
                            app:boxCornerRadiusBottomStart="10dp"
                            app:boxCornerRadiusBottomEnd="10dp">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etSrmcIp"
                                android:layout_width="match_parent"
                                android:layout_height="52dp"
                                android:hint="@string/hint_server_ip_placeholder"
                                android:textColor="@color/text_primary"
                                android:textSize="14sp"
                                android:inputType="textUri"
                                android:imeOptions="actionNext"/>
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            android:hint="@string/hint_server_port"
                            app:startIconDrawable="@drawable/ic_port"
                            app:startIconTint="@color/icon_muted"
                            app:boxStrokeColor="@color/primary"
                            app:boxStrokeWidth="1dp"
                            app:boxStrokeWidthFocused="1.5dp"
                            app:hintTextColor="@color/primary"
                            app:boxCornerRadiusTopStart="10dp"
                            app:boxCornerRadiusTopEnd="10dp"
                            app:boxCornerRadiusBottomStart="10dp"
                            app:boxCornerRadiusBottomEnd="10dp">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etSrmcPort"
                                android:layout_width="match_parent"
                                android:layout_height="52dp"
                                android:hint="@string/hint_server_port_placeholder"
                                android:textColor="@color/text_primary"
                                android:textSize="14sp"
                                android:inputType="number"
                                android:imeOptions="actionDone"/>
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnCheckServer"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:text="@string/btn_check_server"
                            android:textColor="#FFFFFF"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.04"
                            app:backgroundTint="@color/primary"
                            app:cornerRadius="10dp"
                            android:layout_marginBottom="4dp"/>

                        <TextView
                            android:id="@+id/tvSrmcStatus"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp"
                            android:padding="8dp"
                            android:visibility="gone"/>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- INBOUND WEBHOOK section -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_inbound_webhook"
                    android:textSize="11sp"
                    android:textColor="@color/text_tertiary"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="8dp"/>

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/bg_card"
                    app:strokeColor="@color/border_light"
                    app:strokeWidth="1dp"
                    android:layout_marginBottom="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <!-- Webhook URL display (read-only, fetched from server) -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/label_webhook_url"
                            android:textSize="11sp"
                            android:textColor="@color/text_tertiary"
                            android:letterSpacing="0.06"
                            android:layout_marginBottom="6dp"/>

                        <TextView
                            android:id="@+id/tvWebhookUrl"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/label_webhook_url_placeholder"
                            android:textColor="@color/primary"
                            android:textSize="12sp"
                            android:fontFamily="monospace"
                            android:gravity="center_vertical"
                            android:background="@drawable/et_bg_readonly"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"
                            android:paddingTop="12dp"
                            android:paddingBottom="12dp"
                            android:layout_marginBottom="16dp"
                            android:singleLine="true"
                            android:ellipsize="middle"/>

                        <!-- Register / Test button -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnRegisterWebhook"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:text="@string/btn_register_webhook"
                            android:textColor="#FFFFFF"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.04"
                            app:backgroundTint="@color/primary"
                            app:cornerRadius="10dp"
                            android:layout_marginBottom="8dp"/>

                        <!-- Server response display -->
                        <TextView
                            android:id="@+id/tvWebhookStatus"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp"
                            android:padding="10dp"
                            android:background="@drawable/et_bg_readonly"
                            android:visibility="gone"/>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- LOCAL GATEWAY section -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_local_gateway"
                    android:textSize="11sp"
                    android:textColor="@color/text_tertiary"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="8dp"/>

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/bg_card"
                    app:strokeColor="@color/border_light"
                    app:strokeWidth="1dp"
                    android:layout_marginBottom="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/label_device_ip"
                            android:textSize="11sp"
                            android:textColor="@color/text_tertiary"
                            android:letterSpacing="0.06"
                            android:layout_marginBottom="6dp"/>

                        <TextView
                            android:id="@+id/tvIpAddress"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:text="@string/hint_device_ip_placeholder"
                            android:textColor="@color/primary"
                            android:textSize="14sp"
                            android:gravity="center_vertical"
                            android:background="@drawable/et_bg_readonly"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"
                            android:layout_marginBottom="16dp"/>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/border_light"
                            android:layout_marginBottom="16dp"/>

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            android:hint="@string/hint_gateway_port"
                            app:startIconDrawable="@drawable/ic_port"
                            app:startIconTint="@color/icon_muted"
                            app:boxStrokeColor="@color/primary"
                            app:boxStrokeWidth="1dp"
                            app:boxStrokeWidthFocused="1.5dp"
                            app:hintTextColor="@color/primary"
                            app:boxCornerRadiusTopStart="10dp"
                            app:boxCornerRadiusTopEnd="10dp"
                            app:boxCornerRadiusBottomStart="10dp"
                            app:boxCornerRadiusBottomEnd="10dp">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etPort"
                                android:layout_width="match_parent"
                                android:layout_height="52dp"
                                android:hint="@string/hint_gateway_port_placeholder"
                                android:textColor="@color/text_primary"
                                android:textSize="14sp"
                                android:inputType="number"
                                android:imeOptions="actionDone"/>

                        </com.google.android.material.textfield.TextInputLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/border_light"
                            android:layout_marginBottom="16dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/label_api_key"
                            android:textSize="11sp"
                            android:textColor="@color/text_tertiary"
                            android:letterSpacing="0.06"
                            android:layout_marginBottom="6dp"/>

                        <TextView
                            android:id="@+id/tvApiKey"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/label_api_key_placeholder"
                            android:textColor="@color/primary"
                            android:textSize="11sp"
                            android:fontFamily="monospace"
                            android:letterSpacing="0"
                            android:gravity="start|center_vertical"
                            android:background="@drawable/et_bg_readonly"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"
                            android:paddingTop="12dp"
                            android:paddingBottom="12dp"
                            android:layout_marginBottom="16dp"
                            android:singleLine="false"
                            android:maxLines="4"
                            android:ellipsize="none"
                            android:textIsSelectable="true"
                            android:breakStrategy="balanced"/>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/border_light"
                            android:layout_marginBottom="16dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/label_default_sim"
                            android:textSize="11sp"
                            android:textColor="@color/text_tertiary"
                            android:letterSpacing="0.06"
                            android:layout_marginBottom="6dp"/>

                        <!-- SIM 1 -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:baselineAligned="false"
                            android:background="@drawable/et_bg_readonly"
                            android:gravity="center_vertical"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"
                            android:paddingTop="12dp"
                            android:paddingBottom="12dp"
                            android:layout_marginBottom="8dp">

                            <TextView
                                android:id="@+id/tvSimSlot"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/label_sim1_slot"
                                android:textColor="@color/text_primary"
                                android:textSize="13sp"/>

                            <TextView
                                android:id="@+id/tvSimCarrier"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/label_sim_not_detected"
                                android:textColor="@color/primary"
                                android:textSize="12sp"/>

                        </LinearLayout>

                        <!-- SIM 2 -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:baselineAligned="false"
                            android:background="@drawable/et_bg_readonly"
                            android:gravity="center_vertical"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"
                            android:paddingTop="12dp"
                            android:paddingBottom="12dp"
                            android:layout_marginBottom="8dp">

                            <TextView
                                android:id="@+id/tvSim2Slot"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/label_sim2_slot"
                                android:textColor="@color/text_primary"
                                android:textSize="13sp"/>

                            <TextView
                                android:id="@+id/tvSim2Carrier"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/label_sim_not_detected"
                                android:textColor="@color/primary"
                                android:textSize="12sp"/>

                        </LinearLayout>

                        <!-- SIM mode indicator / picker -->
                        <TextView
                            android:id="@+id/tvDualSimStatus"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="↻ Round-robin — tap to change"
                            android:textColor="#4CAF50"
                            android:textSize="11sp"
                            android:paddingStart="4dp"
                            android:paddingTop="4dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:background="?attr/selectableItemBackground"/>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>