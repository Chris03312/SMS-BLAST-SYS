<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_deep"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:weightSum="1">

        <!-- HERO BLOCK -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:background="@drawable/bg_hero_gradient"
            android:clipChildren="false"
            android:clipToPadding="false">

            <View
                android:layout_width="180dp"
                android:layout_height="180dp"
                android:background="@drawable/shape_circle_accent"
                android:alpha="0.06"
                android:layout_alignParentEnd="true"
                android:layout_marginEnd="-60dp"
                android:layout_marginTop="-40dp"/>

            <View
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:background="@drawable/shape_circle_accent"
                android:alpha="0.05"
                android:layout_alignParentStart="true"
                android:layout_alignParentBottom="true"
                android:layout_marginStart="-30dp"
                android:layout_marginBottom="-40dp"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_centerInParent="true">

                <androidx.cardview.widget.CardView
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="22dp"
                    app:cardElevation="12dp"
                    android:layout_marginBottom="16dp">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:contentDescription="@string/content_desc_logo"
                        android:padding="12dp"
                        android:scaleType="fitCenter"
                        android:src="@drawable/logo"/>

                </androidx.cardview.widget.CardView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/app_name"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:letterSpacing="0.02"
                    android:layout_marginBottom="6dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_sms_gateway"
                    android:textSize="11sp"
                    android:textColor="#BBDEFB"
                    android:letterSpacing="0.18"
                    android:textAllCaps="true"/>

            </LinearLayout>
        </RelativeLayout>

        <!-- WAVE DIVIDER -->
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="32dp"
            android:scaleType="fitXY"
            android:src="@drawable/wave_divider"
            android:contentDescription="@null"/>

        <!-- FORM -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@color/bg_surface"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingTop="28dp"
            android:paddingEnd="24dp"
            android:paddingBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="@string/label_welcome_back"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="28dp"
                android:text="@string/label_sign_in_subtitle"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />


            <!-- ERROR CARD -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardError"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FEF2F2"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="14dp"
                    android:paddingBottom="14dp">

                    <TextView
                        android:id="@+id/tvError"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textColor="#B91C1C"
                        android:textSize="13sp"
                        android:lineSpacingExtra="2dp"
                        android:drawableStart="@drawable/ic_error"
                        android:drawableTint="#B91C1C"
                        android:drawablePadding="10dp"
                        android:gravity="center_vertical"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- USER ID -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:letterSpacing="0.12"
                android:text="@string/label_user_id"
                android:textColor="@color/text_label"
                android:textSize="11sp"
                android:textStyle="bold" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilUserId"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:hint="@string/hint_user_id"
                app:boxBackgroundColor="@color/input_bg"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusTopStart="12dp"
                app:boxStrokeColor="@color/primary"
                app:boxStrokeWidth="1.5dp"
                app:boxStrokeWidthFocused="2dp"
                app:hintTextColor="@color/primary"
                app:startIconDrawable="@drawable/ic_person"
                app:startIconTint="@color/icon_tint">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etUserId"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:imeOptions="actionNext"
                    android:inputType="text"
                    android:paddingStart="40dp"
                    android:paddingEnd="12dp"
                    android:singleLine="true"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- PASSWORD -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:letterSpacing="0.12"
                android:text="@string/label_password"
                android:textColor="@color/text_label"
                android:textSize="11sp"
                android:textStyle="bold" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilPassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                android:hint="@string/hint_password"
                app:boxBackgroundColor="@color/input_bg"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusTopStart="12dp"
                app:boxStrokeColor="@color/primary"
                app:boxStrokeWidth="1.5dp"
                app:boxStrokeWidthFocused="2dp"
                app:endIconMode="password_toggle"
                app:endIconTint="@color/icon_tint"
                app:hintTextColor="@color/primary"
                app:startIconDrawable="@drawable/ic_lock"
                app:startIconTint="@color/icon_tint">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etPassword"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:imeOptions="actionDone"
                    android:inputType="textPassword"
                    android:paddingStart="40dp"
                    android:paddingEnd="12dp"
                    android:singleLine="true"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- SIGN IN BUTTON -->

            <!-- PROGRESS -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLogin"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:backgroundTint="@color/primary"
                android:letterSpacing="0.06"
                android:text="@string/btn_sign_in"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                app:cornerRadius="14dp"
                app:icon="@drawable/ic_arrow_forward"
                app:iconGravity="end"
                app:iconTint="#FFFFFFCC" />

            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:id="@+id/progressBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:indeterminate="true"
                android:visibility="gone"
                app:indicatorColor="@color/primary"
                app:trackColor="@color/primary_10"
                app:trackCornerRadius="4dp" />

        </LinearLayout>
        
        <!-- SECURITY FOOTER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/bg_surface"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingTop="8dp"
            android:paddingBottom="12dp">

            <TextView
                android:id="@+id/tvServerInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textColor="@color/text_tertiary"
                android:textSize="11sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/label_copyright"
                android:textColor="@color/text_tertiary"
                android:textSize="11sp" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>